{
  "name": "Rust Multi-Service Dev Environment",
  "build": {
    "dockerfile": "Containerfile",
    "target": "developmental"
  },
  
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "true",
      "configureZshAsDefaultShell": "true",
      "installOhMyZsh": "true",
      "ohMyZshTheme": "agnoster"
    },
    "ghcr.io/devcontainers/features/node:2": {
      "version": "lts"
    }
  },
  
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "vadimcn.vscode-lldb",
        "robert-neff.vscode-just"
      ]
    }
  },

  // 1. Cleaned mount syntax: Strip out the invalid ",userns=keep-id" token
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/rust_contain,type=bind",

  "overrideCommand": true,
  "shutdownAction": "stopContainer",

  // 2. Native placement: Pass the flag directly where Podman 4.9 expects it
  "runArgs": [
    "--userns=keep-id",
    "--security-opt", "label=disable",
    "--no-hosts"
  ],
  
  "remoteUser": "iktome",
  "updateRemoteUserUID": true,
  "postCreateCommand": "cargo check"
}